# ========================================
# XCI Backend Environment Configuration
# ========================================

# ---- DATABASE ----
# For local development:
MONGO_URI=mongodb://localhost:27017/agrisen

# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://agrisen_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

DB_NAME=agrisen

# ---- JWT AUTHENTICATION ----
# Change this to a strong random string in production
# Generate using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- REDIS CACHE ----
# For local development:
REDIS_URL=redis://localhost:6379

# For Redis Cloud:
# REDIS_URL=redis://:YOUR_PASSWORD@redis-xxxxx.cloud.redislabs.com:xxxxx

# ---- EMAIL CONFIGURATION ----
# For Gmail with App Password:
# 1. Enable 2FA on Gmail
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate 16-char app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_FROM=AgriSen <noreply@agrisen.com>

# For local testing (simulated email):
# SMTP_USER=dummy
# SMTP_PASSWORD=dummy

# ---- GOOGLE OAUTH (Optional) ----
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ---- WEATHER API (Optional) ----
# Get free key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key

# Get free key from: https://www.weatherapi.com/
WEATHERAPI_KEY=your_weatherapi_key

# ---- AI CHAT SERVICE (Optional) ----
# Get free key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# ---- ENVIRONMENT ----
ENVIRONMENT=development
# For production: ENVIRONMENT=production

# ---- FRONTEND URL (for CORS) ----
FRONTEND_URL=http://localhost:5173
# For production: FRONTEND_URL=https://your-frontend-domain.com
